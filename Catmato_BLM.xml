		<set name="physws">
			<hands>Jhakri Cuffs</hands>
			<legs augment="S4538629517158636934">Merlinic Shalwar</legs>
			<feet augment="S152095976860124646">Merlinic Crackows</feet>
			<neck>Clotharius Torque</neck>
			<ear1>Moonshade Earring</ear1>
			<ear2>Cessance Earring</ear2>
			<ring1>Petrov Ring</ring1>
			<ring2>Shukuyu Ring</ring2>
		</set>
		<set name="magicws">
			<ammo>Hydrocera</ammo>
			<head>Volte Beret</head>
			<body augment="S141032100907141">Merlinic Jubbah</body>
			<hands augment="D15479298603780">Amalric Gages</hands>
			<legs augment="S4538629517158636934">Merlinic Shalwar</legs>
			<feet>Jhakri Pigaches +2</feet>
			<neck>Sanctity Necklace</neck>
			<waist>Eschan Stone</waist>
			<ear1>Friomisi Earring</ear1>
			<ear2>Malignance Earring</ear2>
			<ring1>Mallquis Ring</ring1>
			<ring2>Vertigo Ring</ring2>
