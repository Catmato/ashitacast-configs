			<waist>Fucho-no-Obi</waist>
			<ear1>Gifted Earring</ear1>
			<ear2>Malignance Earring</ear2>
			<ring1>Excelsis Ring</ring1>
			<ring2>Evanescence Ring</ring2>
			<back>Perimede Cape</back>
		</set>
		<set name="fastcast">
			<main>Oranyan</main>
			<sub>Niobid Strap</sub>
			<ammo>Hydrocera</ammo>
			<head>Welkin Crown</head>
			<body augment="S44582304692736138819652">Merlinic Jubbah</body>
			<hands>Regal Cuffs</hands>
			<legs augment="D15479298603780">Amalric Slops</legs>
			<feet>Merlinic Crackows</feet>
			<neck>Voltsurge Torque</neck>
			<waist>Embla Sash</waist>
			<ear1>Malignance Earring</ear1>
			<ear2>Loquac. Earring</ear2>
