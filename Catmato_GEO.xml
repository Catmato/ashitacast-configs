	<variables>
		<var name="mpbody">0</var>
	</variables>
	
	<inputcommands>
		<cmd input="/mpbodyon">
			<setvar name="mpbody" value="1"/>
			<addtochat color="50">======== MP Body enabled ========</addtochat>
		</cmd>
		<cmd input="/mpbodyoff">
			<setvar name="mpbody" value="0"/>
			<addtochat color="50">======== MP Body disabled ========</addtochat>
		</cmd>
	</inputcommands>

	<idlegear>
			<if p_status="resting">
				<equip set="Resting" />
			</if>
			<else>
				<if pet_active="true">
					<equip set="standluopan"/>
				</if>
				<else>
					<equip set="Stand" />
				</else>
			</else>
			<if e_area="*Remnants|Periqia|Ilrusi Atoll|Mamool Ja Training Grounds|Lebros Caverns|Leujoaom Sanctum|Nyzul Isle|The Ashu Talif"><equip><lring>Balrahn's Ring</lring></equip></if>
			
			<if e_area="Maquette Abdhaljs-Legion"><equip><lring>Maquette Ring</lring></equip></if>
			<if p_status="engaged">
				<equip set="TP" />
			</if>
	</idlegear>

	<premagic>	
		<equip set="Precast" />
		<if ad_name="Cure*|Cura*">
			<equip set="cureprecast" />
		</if>
		<if ad_skill="elementalmagic">
			<equip>
				<hands>Bagua Mitaines +1</hands>
			</equip>
		</if>
		<if ad_name="Impact">
			<equip><body>Twilight Cloak</body></equip>
		</if>
	</premagic>


	<midmagic>
		<if ad_name="Geo-*"><equip set="Geo" /></if>
		<if ad_name="Indi*"><equip set="Indi" /></if>
		<if ad_name="Drain*|Aspir*"><equip set="Drain" /></if>
		<if ad_name="Stun"><equip set="stun" /></if>
			
		<if ad_name="Stoneskin">
			<equip set="Stoneskin" />
		</if>
		<if ad_name="Cure*">
			<if t_name="Catmato">
				<equip set="cureme" />
			</if>
			<if buffactive="184">
				<equip set="auroracure" />
			</if>
			<else>	
				<equip set="Curing" />
			</else>
		</if>
		<if ad_skill="ElementalMagic">
			<if ad_name="Impact"><equip set="Impact" /></if>
			<if advanced="$mpbody=1">
			<else>
				<equip when="$GearTime" set="mpnuke" />
				<if advanced="%ad_element=%e_dayelement">
					<if ad_element="Light">
						<equip>
							<waist>Korin Obi</waist>
						</equip>
					</if>
					<equip>
						<!--<rring>Zodiac Ring</rring>-->
						<back>Twilight Cape</back>
					</equip>
				</if>
				<elseif advanced="%ad_element=%e_weatherelement">
					<if ad_element="Light">
						<equip when="midcast">
							<waist>Korin Obi</waist>
						</equip>
					</if>
					<equip>
						<back>Twilight Cape</back>
					</equip>
				</elseif>
			</else>
			</if>
			<else>
				<equip when="$GearTime" set="Nuke" />
				<if advanced="%ad_element=%e_dayelement">
					<if ad_element="Light">
						<equip>
							<waist>Korin Obi</waist>
						</equip>
					</if>
					<equip>
						<!--<rring>Zodiac Ring</rring>-->
						<back>Twilight Cape</back>
					</equip>
				</if>
				<elseif advanced="%ad_element=%e_weatherelement">
					<if ad_element="Light">
						<equip when="midcast">
							<waist>Korin Obi</waist>
						</equip>
					</if>
					<equip>
						<back>Twilight Cape</back>
					</equip>
				</elseif>
			</else>
		</if>
		<if ad_skill="EnfeeblingMagic">
			<if ad_name="Slow|Paralyze"><equip set="Enfeeb-MND" /></if>
			<else><equip set="Enfeeb-ACC" /></else>		
		</if>
		<if ad_skill="EnhancingMagic">
			<equip set="Enhancing" />
		</if>
	</midmagic>
	<weaponskill>
		<if ad_name="Cataclysm|Flash Nova|Rock Crusher|Earch Crusher">
			<equip set="nuke" />
		</if>
	</weaponskill>
</ashitacast>