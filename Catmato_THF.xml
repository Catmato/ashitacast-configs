	<variables>
		<var name="Set">Old</var>
		<var name="TH">TH</var>
		<var name="autows">off</var>
		<var name="autosamba">off</var>
		<var name="ReadySC">0</var>
		<var name="-enmity">off</var>
		<var name="wstoauto">Evisceration</var>
		<var name="incombat">no</var>
	</variables>

	<inputcommands>

		<cmd input="/wson">
			<setvar name="autows" value="on"/>
			<addtochat color="50">======== AutoWS enabled: $wstoauto ========</addtochat>
		</cmd>
		<cmd input="/wsoff">
			<setvar name="autows" value="off"/>
			<addtochat color="50">======== AutoWS disabled ========</addtochat>
		</cmd>
		<cmd input="/sambaon">
			<setvar name="autosamba" value="on"/>
			<addtochat color="50">======== AutoSamba enabled ========</addtochat>
		</cmd>
		<cmd input="/sambaoff">
			<setvar name="autosamba" value="off"/>
			<addtochat color="50">======== AutoSamba disabled ========</addtochat>
		</cmd>
		<cmd input="/enmityon">
			<setvar name="-enmity" value="on"/>
			<addtochat color="50">======== Low Enmity mode enabled ========</addtochat>
		</cmd>
		<cmd input="/enmityoff">
			<setvar name="-enmity" value="off"/>
			<addtochat color="50">======== Low Enmity mode disabled ========</addtochat>
		</cmd>
	</inputcommands>

	<premagic>
		<equip set="fastcast" />
		<if ad_name="Utsusemi*">
			<equip set="utcast"/>
		</if>
	</premagic>


	<idlegear>
		<if p_tp="<1000" advanced="$ReadySC=0">
			<setvar name="ReadySC" value="1"/>
		</if>
		<if p_status="engaged">
			<equip set="tp"/>
				<if buffactive="!16">
					<if advanced="$autows=on" advanced="$ReadySC=1">
						<if advanced="(%p_tp>999)&(%t_distance<5)">
								<setvar name="ReadySC" value="0"/>
								<command>/ws "$wstoauto" &lt;t&gt;</command>
								<command delay="1500">/ac var set ReadySC 1</command>
							</if>
					</if>
					<if advanced="$autosamba=on">
						<if p_tp=">350&<999">
							<if buffactive="!370">
								<command>/ja "Haste Samba" &lt;me&gt;</command>
							</if>
						</if>
					</if>
				</if>
				<if buffactive="65">
					<equip set="sneakattack"/>
				</if>
		</if>
		<else>
			<equip set="Standard" />
		</else>
	</idlegear>

	<jobability>
		<if ad_name="Quickstep|Box Step"><equip set="Steps" /></if>
		<!--<if spell="Flee"><equip when="precast"><feet>Rogue's Poulaines</feet></equip></if>-->
		<if ad_name="Assassin's Charge">
			<equip><feet>Asn. Poulaines +2</feet></equip>
		</if>
		<if ad_name="Feint">
			<equip><legs>Asn. Culottes +2</legs></equip>
		</if>
		<if ad_name="Perfect Dodge"><equip><hands>Plunderer's Armlets +1</hands></equip></if>
		<if ad_name="jump"><equip set="th" /></if>
		<if ad_name="hide"><equip><body>Pillager's Vest +1</body></equip></if>
		<if ad_name="steal"><equip set="steal" /></if>
	</jobability>

	<weaponskill>
		<if ad_name="Exenterator"><equip set="Exenterator" /></if>
		<if ad_name="Evisceration"><equip set="Evisceration" /></if>
		<if ad_name="Rudra's Storm"><equip set="rudras" /></if>
			<if buffactive="65">
				<equip set="SARudras"/>
			</if>
		<if ad_name="Mandalic Stab"><equip set="Mandalic-$Set" /></if>
		<if ad_name="Shark Bite"><equip set="Shark-$Set" /></if>
		<if ad_name="Dancing Edge"><equip set="DE-$Set" /></if>
		<if ad_name="Aeolian Edge|Cyclone|Gust Slash"><equip set="aeolian" /></if>

		<if ad_name="Savage Blade|True Strike|Swift Blade"><equip set="savage" /></if>
			<if buffactive="65">
				<equip set="SASavage"/>
			</if>
	</weaponskill>
</ashitacast>