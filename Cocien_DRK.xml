<ashitacast>
    <settings> <!--Contains settings specific to this xml, must be set to true/false to override default-->
        <buffupdate>false</buffupdate> <!--Determines if your idlegear will be parsed when you gain/lose a buff. Default: TRUE -->
        <statusupdate>true</statusupdate> <!--Determines if your idlegear will be parsed when you change status(stand/rest/engage/etc).  Default: TRUE -->
        <hpupdate>false</hpupdate> <!--Determines if your idlegear will be parsed when your HP % changes.  Default: TRUE -->
        <autoupdate>true</autoupdate> <!--Determines if your idlegear will be parsed on outgoing status updates(roughly every 350ms).  Default: TRUE-->
    </settings>
    <sets>
		<set name="dt">
			<sub>Utu Grip</sub>
			<ammo>Staunch Tathlum</ammo>
			<head>Sulevia's Mask +1</head>
			<body>Tartarus Platemail</body>
			<hands>Sulev. Gauntlets +2</hands>
			<legs>Sulevi. Cuisses +2</legs>
			<feet>Sulev. Leggings +2</feet>
			<neck>Twilight Torque</neck>
			<waist>Ioskeha Belt</waist>
			<ear1>Cryptic Earring</ear1>
			<ear2>Tuisto Earring</ear2>
			<ring1>Defending Ring</ring1>
			<ring2>Warden's Ring</ring2>
			<back>Moonbeam Cape</back>
		</set>
		<set name="TP">
			<ammo>Aurgelmir Orb</ammo>
			<head>Flam. Zucchetto +2</head>
			<body>Flamma Korazin +2</body>
			<hands>Sulev. Gauntlets +2</hands>
			<legs>Odyssean Cuisses</legs>
			<feet>Carmine Greaves +1</feet>
			<neck>Abyssal Beads +1</neck>
			<waist>Windbuffet Belt +1</waist>
			<!-- <waist>Orpheus's Sash</waist> -->
			<ear1>Mache Earring +1</ear1>
			<ear2>Cessance Earring</ear2>
			<ring1>Chirich Ring +1</ring1>
			<ring2>Petrov Ring</ring2>
			<!-- <back augment="S2651484650913033">Mecisto. Mantle</back> -->
			<back augment="S255463270418759">Ankou's Mantle</back>
		</set>
		<set name="Resting">
			<ammo>Staunch Tathlum</ammo>
			<head>Flam. Zucchetto +2</head>
			<body>Sulevia's Plate. +2</body>
			<hands>Sulev. Gauntlets +2</hands>
			<legs>Carmine Cuisses +1</legs>
			<feet>Flam. Gambieras +2</feet>
			<neck>Beak Necklace</neck>
			<waist>Hierarch Belt</waist>
			<ear1>Brutal Earring</ear1>
			<ear2>Antivenom Earring</ear2>
			<ring1>Rajas Ring</ring1>
			<ring2>Warp Ring</ring2>
		</set>
		<set name="Moving" Baseset="Idle">
		    <legs>Carmine Cuisses +1</legs>
		</set>	
		<set name="WS">
			<ammo>Knobkierrie</ammo>
			<head>Ratri sallet</head>
			<body>Ratri Plate</body>
			<hands>Ratri Gadlings</hands>
			<legs augment="M1372">Fall. Flanchard +2</legs>
			<feet>Sulev. leggings +2</feet>
			<ear1>Ishvara Earring</ear1>
			<ear2>Moonshade Earring</ear2>
			<ring1>Karieyh Ring</ring1>
			<ring2>Epaminondas's Ring</ring2>
			<waist>Fotia Belt</waist>
			<neck>Fotia Gorget</neck>
			<back augment="S255463270418759">Ankou's Mantle</back>
		</set>
		<set name="Precast">
			<head augment="S26496199297047">Odyssean Helm</head>
			<body augment="M3335">Fall. Cuirass +3</body>
			<ear2>Loquac. Earring</ear2>
			<ring1>Kishar Ring</ring1>
			<ring2>Prolix Ring</ring2>
		</set>
		<set name="Dark">
			<ammo>Hydrocera</ammo>
			<head>Pixie Hairpin +1</head>
			<body augment="M3335">Fall. Cuirass +3</body>
			<hands augment="M1371">Fall. Fin. Gaunt. +2</hands>
			<legs>Eschite Cuisses</legs>
			<neck>Erra Pendant</neck>
			<ear2>Hecate's Earring</ear2>
			<ring1>Kishar Ring</ring1>
			<ring2>Evanescence Ring</ring2>
			<back augment="S255463270418759">Ankou's Mantle</back>
		</set>
		<set name="Idle">
			<ammo>Staunch Tathlum</ammo>
			<head>Ratri Sallet</head>
			<body augment="M3335">Fall. Cuirass +3</body>
			<hands augment="M1371">Fall. Fin. Gaunt. +2</hands>
			<legs augment="M1372">Fall. Flanchard +2</legs>
			<feet augment="M1373">Fall. Sollerets +2</feet>
			<neck>Bathy Choker</neck>
			<waist>Ioskeha Belt</waist>
			<ear1>Infused Earring</ear1>
			<ear2>Cessance Earring</ear2>
			<ring1>Stikini Ring +1</ring1>
			<ring2>Paguroidea Ring</ring2>
			<back augment="S255463270418759">Ankou's Mantle</back>
		</set>
    </sets>
	<inputcommands>
		<cmd input="/dt">
		     <setvar name="dmg" value="1"/>
			 <addtochat color="50">DT IS ACTIVE</addtochat>
		</cmd>
        <cmd input="/dtoff">
             <setvar name="dmg" value="0"/>
             <addtochat color="50">DT IS OFF</addtochat>
        </cmd>		
		<cmd input="/gsws">
		     <setvar name="autogsws" value="1"/>
		     <addtochat color="50">Auto GS WS GOOOO!!!</addtochat>
        </cmd>
				<cmd input="/gswsoff">
		     <setvar name="autogsws" value="0"/>
		     <addtochat color="50">Auto GS WS OFF</addtochat>
        </cmd>
		<cmd input="/sws">
		     <setvar name="autosws" value="1"/>
		     <addtochat color="50">Scythe Auto WS GOOOO!!!</addtochat>
        </cmd>
		<cmd input="/swsoff">
		     <setvar name="autosws" value="0"/>
		     <addtochat color="50">Scythe Auto WS OFF</addtochat>
        </cmd>
		<cmd input="/cat">
		     <setvar name="autocat" value="1"/>
		     <addtochat color="50">Auto Catastrophe GOOOO!!!</addtochat>
        </cmd>
		<cmd input="/catoff">
		     <setvar name="autocat" value="0"/>
		     <addtochat color="50">Auto Catastrophe OFF</addtochat>
        </cmd>
		<cmd input="/solo">
			<setvar name="solosc" value="1"/>
			<setvar name="ReadySC" value="1"/>
			<setvar name="stop" value="1"/>
			<setvar name="backup" value="1"/>
			<addtochat	color="50">Solo SC On</addtochat>
		</cmd>
		<cmd input="/soloff">
			<setvar name="solosc" value="0"/>
			<setvar name="stop" value="0"/>
			<setvar name="backup" value="0"/>
			<addtochat color="50">Solo SC OFF</addtochat>
		</cmd>
		
		<cmd input="/toron">
		     <setvar name="autotor" value="1"/>
		     <addtochat color="50">Auto Tor GOOOO!!!</addtochat>
        </cmd>
		<cmd input="/toroff">
		     <setvar name="autotor" value="0"/>
		     <addtochat color="50">Auto Tor OFF</addtochat>
        </cmd>
    </inputcommands>
    <premagic>
	 <equip set="Precast" />
    </premagic>
    <midmagic>
	 <equip set="Dark" />
	</midmagic>
	<jobability>
		<if ad_name="Souleater">
		<equip><head>Igno. Burgeonet +1</head></equip>
		<equip><legs augment="M1372">Fall. Flanchard +2</legs></equip>
		</if>
		<if ad_name="Nether Void"><equip><legs>Heath. Flanchard +1</legs></equip></if>
		<if ad_name="Diabolic Eye"><equip><hands augment="M1371">Fall. Fin. Gaunt. +2</hands></equip></if>
		<if ad_name="Blood Weapon"><equip><body augment="M3335">Fall. Cuirass +3</body></equip></if>
		<if ad_name="Dark Seal"><equip><head augment="M1370">Fall. Burgeonet +1</head></equip></if>
		<if ad_name="Arcane Circle"><equip><feet>Ignominy Sollerets +2</feet></equip></if>
		<if ad_name="Weapon Bash"><equip><hands>Ignominy Gauntlets +3</hands></equip></if>
		<if ad_name="Last Resort"><equip><feet>Fall. Sollerets +1</feet></equip></if>
	</jobability>
	<weaponskill>
        <equip set="WS" />
    </weaponskill>
    <idlegear>
        <if p_status="idle">
            <equip set="Idle" />
        </if>
        <if p_status="engaged">
            <equip set="TP" />
        </if>
        <if p_status="resting">
            <equip set="Resting" />
        </if>
		<if advanced="$autogsws=1">
		    <if buffactive="Aftermath">
			<if p_status="Engaged">
		        <if p_tp=">999">
		          <command>/ws "Torcleaver" &lt;t&gt;</command>
		        </if>
		   </if>
		   </if>
		    <else>
			<if p_status="Engaged">
		       <if p_tp=">2999">
		          <command>/ws "Scourge" &lt;t&gt;</command>
			   </if>
			</if>   
		    </else>
		</if>
	   <if advanced="$autocat=1">
			<if p_status="Engaged">
				<if p_tp=">999">
				<command>/ws "Catastrophe" &lt;t&gt;</command>
				</if>
			</if>
	   </if>
		<if advanced="$dmg=1"> 
		    <equip set="dt" />
		</if>
		<!-- Solo Skill Chain Shit -->
		<if p_tp=">999" p_status="Engaged" advanced="$ReadySC=1" advanced="$stop=1">
		<!-- <command>/ac print uvars</command> -->
			<if advanced="$solosc=1">
					<setvar name="ReadySC" value="0"/>
					<command>/ws "Resolution" &lt;t&gt;</command>
					<setvar name="solosc" value="2"/>
			</if>
			<elseif advanced="$solosc=2">
					<setvar name="ReadySC" value="0"/>
					<command>/ws "Scourge" &lt;t&gt;</command>
					<setvar name="solosc" value="3"/>
			</elseif>
			<elseif advanced="$solosc=3">
					<setvar name="ReadySC" value="0"/>
					<command>/ws "Scourge" &lt;t&gt;</command>
					<setvar name="solosc" value="1"/>
			</elseif>
		</if>
		<if p_tp="<1000">
			<setvar name="ReadySC" value="1"/>
		</if>
		<if p_status="Idle">
			<setvar name="ReadySC" value="1"/>
			<setvar name="solosc" value="1"/>
		</if>
		<if p_tp=">2999" p_status="Engaged" advanced="$backup=1" advanced="$stop=1">
			<setvar name="solosc" value="2"/>
			<command>/ws "Resolution" &lt;t&gt;</command>
		</if>
		
		<if advanced="$autotor=1">
		   <if p_tp=">1000">
		   <if p_status="Engaged">
		      <equip set="WS" />  
		      <command>/ws "Torcleaver" &lt;t&gt;</command>
		   </if>
		   </if>
		</if>
		<if p_ismoving="true"><equip set="Moving" /></if>	  
	    <if eq_back ="Mecisto. Mantle"><equip lock="true"><back augment="S2651484650913033">Mecisto. Mantle</back></equip></if>	
		<if eq_rring="Warp Ring"><equip lock="true"><rring>Warp Ring</rring></equip></if>
		<if eq_rring="Dim. Ring (Holla)"><equip lock="true"><rring>Dim. Ring (Holla)</rring></equip></if>
		<if eq_rring="Dim. Ring (Dem)"><equip lock="true"><rring>Dim. Ring (Dem)</rring></equip></if>
		<if eq_rring="Dim. Ring (Mea)"><equip lock="true"><rring>Dim. Ring (Mea)</rring></equip></if>
		<if eq_rring="Echad Ring"><equip lock="true"><rring>Echad Ring</rring></equip></if>
		<if eq_rring="Capacity Ring"><equip lock="true"><rring>Capacity Ring</rring></equip></if>
		<if eq_rring="Trizek Ring"><equip lock="true"><rring>Trizek Ring</rring></equip></if>
		<if eq_rring="Facility Ring"><equip lock="true"><rring>Facility Ring</rring></equip></if>
    </idlegear>

</ashitacast>
