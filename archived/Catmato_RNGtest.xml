<ashitacast>
	<settings>
		<buffupdate>false</buffupdate>
		<statusupdate>false</statusupdate>
		<hpupdate>false</hpupdate>
		<autoupdate>true</autoupdate>
	</settings>
	<sets>
		<set name="standard">
			<ammo>Wooden Arrow</ammo>
			<legs>Carmine Cuisses +1</legs>
		</set>
		<set name="wildfire">
			<head augment="S94274868101411615200324">Herculean Helm</head>
			<body augment="S365904440996091346793540">Herculean Vest</body>
			<hands>Mummu Wrists</hands>
			<legs>Iuitl Tights +1</legs>
			<feet>Mummu Gamash. +1</feet>
			<neck>Sanctity Necklace</neck>
			<waist>Fotia Belt</waist>
			<ear1>Strophadic Earring</ear1>
			<ear2>Moldavite Earring</ear2>
			<ring1>Regal Ring</ring1>
			<ring2>Ilabrat Ring</ring2>
			<back>Izdubar Mantle</back>
		</set>
		<set name="tpacc">
			<head>Mummu Bonnet +2</head>
			<body>Malignance Tabard</body>
			<hands>Meg. Gloves +2</hands>
			<legs augment="D6232182625036">Carmine Cuisses +1</legs>
			<feet>Mummu Gamash. +1</feet>
			<neck>Combatant's Torque</neck>
			<waist>Kentarch Belt +1</waist>
			<ear1>Mache Earring</ear1>
			<ear2>Steelflash Earring</ear2>
			<ring1>Adler Ring</ring1>
			<ring2>Patricius Ring</ring2>
			<back>Agema Cape</back>
		</set>
		<set name="th">
			<head augment="S94274868101411615200324">Herculean Helm</head>
			<legs augment="S942746044828124646">Herculean Trousers</legs>
		</set>
		<set name="savagecape">
			<back augment="S8136641508812818759">Belenus's Cape</back>
		</set>
		<set name="savagebladeenmity" baseset="savageblade">
			<ammo>Aeolus Arrow</ammo>
		</set>
		<set name="savageblade">
			<range augment="M39265">Sparrowhawk +2</range>
			<ammo>Hauksbok Arrow</ammo>
			<head augment="S6377209853135124601">Herculean Helm</head>
			<body augment="S365904440996091346793540">Herculean Vest</body>
			<hands>Meg. Gloves +2</hands>
			<legs augment="S182076079662084240">Samnuha Tights</legs>
			<feet augment="S35292304617540">Herculean Boots</feet>
			<neck>Combatant's Torque</neck>
			<waist>Kentarch Belt +1</waist>
			<ear1 augment="S560011287">Moonshade Earring</ear1>
			<ear2>Ishvara Earring</ear2>
			<ring1>Rufescent Ring</ring1>
			<ring2>Regal Ring</ring2>
			<back augment="S8136641508812818759">Belenus's Cape</back>
		</set>
		<set name="tp">
			<main>Naegling</main>
			<sub>Odium</sub>
			<range augment="M39265">Sparrowhawk +2</range>
			<ammo>Wooden Arrow</ammo>
			<head>Malignance Chapeau</head>
			<body>Malignance Tabard</body>
			<hands>Malignance Gloves</hands>
			<legs augment="D6232182625036">Carmine Cuisses +1</legs>
			<feet>Malignance Boots</feet>
			<neck>Combatant's Torque</neck>
			<waist>Sailfi Belt +1</waist>
			<ear1>Steelflash Earring</ear1>
			<ear2>Bladeborn Earring</ear2>
			<ring1>Chirich Ring +1</ring1>
			<ring2>Chirich Ring +1</ring2>
			<back augment="S35285710969345541542546">Belenus's Cape</back>
		</set>
		<include>
		</include>
	</sets>
	<variables>
		<var name="autows">off</var>
		<var name="autosamba">off</var>
		<var name="ReadySC">0</var>
		<var name="-enmity">off</var>
	</variables>
	<inputcommands>
		<cmd input="/wson">
			<setvar name="autows" value="on"/>
			<addtochat color="50">======== AutoWS enabled ========</addtochat>
		</cmd>
		<cmd input="/wsoff">
			<setvar name="autows" value="off"/>
			<addtochat color="50">======== AutoWS disabled ========</addtochat>
		</cmd>
		<cmd input="/sambaon">
			<setvar name="autosamba" value="on"/>
			<addtochat color="50">======== AutoSamba enabled ========</addtochat>
		</cmd>
		<cmd input="/sambaoff">
			<setvar name="autosamba" value="off"/>
			<addtochat color="50">======== AutoSamba disabled ========</addtochat>
		</cmd>
		<cmd input="/enmityon">
			<setvar name="-enmity" value="on"/>
			<addtochat color="50">======== Low Enmity mode enabled ========</addtochat>
		</cmd>
		<cmd input="/enmityoff">
			<setvar name="-enmity" value="off"/>
			<addtochat color="50">======== Low Enmity mode disabled ========</addtochat>
		</cmd>
	</inputcommands>
	<idlegear>
		<if p_tp="<1000" advanced="$ReadySC=0">
			<setvar name="ReadySC" value="1"/>
		</if>
		<if p_status="engaged">
			<equip set="tp"/>
				<if buffactive="!16">
					<if advanced="$autows=on" advanced="$ReadySC=1">
						<if advanced="(%p_tp>999)&(%t_distance<5)">
								<setvar name="ReadySC" value="0"/>
								<command>/ws Savage Blade &lt;t&gt;</command>
								<command delay="1500">/ac var set ReadySC 1</command>
							</if>
					</if>
					<if advanced="$autosamba=on">
						<if p_tp=">350&<999">
							<if buffactive="!370">
								<command>/ja "Haste Samba" &lt;me&gt;</command>
							</if>
						</if>
					</if>
				</if>
		</if>
		<else>
			<equip set="Standard" />
		</else>
	</idlegear>
	<preranged>
		<equip>
			<ammo>Wooden Arrow</ammo>
		</equip>
	</preranged>
	<midranged>
		<equip>
			<ammo>Wooden Arrow</ammo>
		</equip>
	</midranged>
	<premagic>
	</premagic>
	<midmagic>
	</midmagic>
	<jobability>
		<if ad_name="Animated Flourish">
			<equip set="th"/>
		</if>
		<if ad_name="Bounty Shot">
			<equip set="th"/>
			<equip>
				<ammo>Wooden Arrow</ammo>
			</equip>
		</if>
	</jobability>
	<weaponskill>
		<if ad_name="wildfire">
			<equip set="wildfire"/>
		</if>
		<if ad_name="Savage Blade">
			<if advanced="$-enmity=on">
				<equip set="savagebladeenmity"/>
			</if>
			<else>
				<equip set="savageblade"/>
			</else>
		</if>
		<if ad_name="*Arrow|Sidewinder|Jishnu's Radiance">
			<equip>
				<ammo></ammo>
			</equip>
		</if>
	</weaponskill>
</ashitacast>