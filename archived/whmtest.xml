	<variables>
		<var name="autows">off</var><!--is autoWS mode on-->
		<var name="autoboost">off</var>
		<var name="autoauspice">off</var>
		<var name="autoreraise">off</var>
		<var name="autoprotect">off</var>
		<var name="autoshell">off</var>
