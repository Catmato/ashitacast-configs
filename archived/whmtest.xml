	<idlegear>
		<if p_tp="&lt;1000" advanced="$ReadySC=0"><!--if i have less than 1000 tp, im not in the process of WSing-->
			<setvar name="ReadySC" value="1"/><!--set the ws ready value-->
		</if>
		<if p_status="engaged"><!--TP rules-->
			<if advanced="(%eq_main=Kraken Club)|(%eq_sub=Kraken Club)"><!--check if kraken is equipped-->
				<equip set="krakentp"/><!--equip kraken-specific tp set-->
			</if>
			<else>
				<equip set="tp"/><!--equip regular tp set-->
				<if p_subjob="DNC">
					<equip><sub>Kraken Club</sub></equip>
				</if>
				<else>
					<equip><sub>Genmei Shield</sub></equip>
				</else>
			</else>
			<!--AUTOMATION SECTION-->
			<if buffactive="!16&!10&!2&!19$!14&!17&!28"><!--check for amnesia(16), stun(10), sleep(2,19), charm(14,17), terror(28) -->
				<!--AUTO WS SECTION-->
				<if advanced="($autows=on)&($ReadySC=1)"><!--is it enabled and not in the process of WSing-->
					<if advanced="(%p_tp>999)&(%t_distance<5)"><!--check for enough tp and distance to mob-->
							<setvar name="ReadySC" value="0"/><!--in the process of WSing to not spam attempts-->
							<command>/ws "$wstoauto" &lt;t&gt;</command><!--use ws-->
							<command delay="1500">/ac var set ReadySC 1</command><!--try again in 1500ms if it didnt fire-->
					</if>
				</if>
				<!--AUTO AFTERMATH SECTION-->
				<if advanced="($autoam=on)&($ReadySC=1)"><!--is it enabled and not in the process of WSing-->
					<if advanced="(%p_tp>999)&(%t_distance<5)"><!--check for enough tp and distance to mob-->
						<if buffactive="272"><!-- check if aftermath is active-->
							<setvar name="ReadySC" value="0"/><!--in the process of WSing to not spam attempts-->
							<command>/ws "$wstoauto" &lt;t&gt;</command><!--use ws-->
							<command delay="1500">/ac var set ReadySC 1</command><!--try again in 1500ms if it didnt fire-->
						</if>
					</if>
					<if advanced="(%p_tp=3000)&(%t_distance<5)&(buffactive=!272)"><!-- build tp to 3000 to get aftermath-->
					<setvar name="ReadySC" value="0"/><!--in the process of WSing to not spam attempts-->
							<command>/ws "$aftermathws" &lt;t&gt;</command><!--use ws-->
							<command delay="1500">/ac var set ReadySC 1</command><!--try again in 1500ms if it didnt fire-->
					</if>
				</if>	
				<!--AUTO SAMBA SECTION-->
				<if advanced="$autosamba=on">
					<if p_tp=">350&<999"><!--do i have enough tp and not ready to WS-->
						<if buffactive="!370"><!--check if haste samba isn't up-->
							<command>/ja "Haste Samba" &lt;me&gt;</command><!--use haste samba-->
						</if>
					</if>
				</if>
			</if>
			<!--HAPPENS UPON ENGAGING-->
			<if advanced="$incombat=no">
				<setvar name="incombat" value="yes"/><!--engaged flag so stuff only triggers once-->
				<!--PRINTS AUTOMATION STATUS IN CHAT-->
				<!--addtochat color="50">======== Low Enmity mode $-enmity ========</addtochat-->
				<addtochat color="50">======== Auto Samba mode $autosamba ========</addtochat>
				<if advanced="$autows=on">
					<addtochat color="50">======== Auto $wstoauto on ========</addtochat>
				</if>
				<else>
					<addtochat color="50">======== AutoWS mode $autows ========</addtochat>
				</else>
			</if>
		</if>
		<if p_status="idle"><!--triggers when not doing anything-->
			<if advanced="$incombat=yes"><!--checks combat flag to get ready for previous section-->
				<setvar name="incombat" value="no"/><!--sets engaged flag off-->
			</if>
			<equip set="Standard" /><!--equip idle gear-->
			<if p_mpp="<50">
				<equip>
					<waist>Fucho-no-obi</waist>
				</equip>
			</if>
			<if p_ismoving="true"><!--check if moving-->
				<equip set="movementspeed"/>
			</if>	
			<if advanced ="%e_area=Bhaflau Thickets">
				<if advanced="$autoboost=on">
					<if buffactive="!119"><!--check if booststr isn't up-->
						<command>/ma "Boost-STR" &lt;me&gt;</command><!--use booststr-->
					</if>
				</if>
				<if advanced="$autoauspice=on">
					<if buffactive="!275"><!--check if auspice isn't up-->
						<command>/ma "auspice" &lt;me&gt;</command><!--use auspice-->
					</if>
				</if>
				<if advanced="$autoreraise=on">
					<if buffactive="!113"><!--check if reraise isn't up-->
						<command>/ma "Reraise IV" &lt;me&gt;</command><!--use reraise-->
					</if>
				</if>
				<if advanced="$autoprotect=on">
					<if buffactive="!40"><!--check if protect isn't up-->
						<command>/ma "protectra V" &lt;me&gt;</command><!--use protect-->
					</if>
				</if>
				<if advanced="$autoshell=on">
					<if buffactive="!41"><!--check if protect isn't up-->
						<command>/ma "shellra V" &lt;me&gt;</command><!--use protect-->
					</if>
				</if>
			</if>
		</if>
		<if p_status="resting"><!--triggers when resting-->
			<equip set="Resting" />
		</if>	
	</idlegear>

